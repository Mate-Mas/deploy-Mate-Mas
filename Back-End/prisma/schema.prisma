generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  usuario
  admin
  superadmin
}

model Usuario {
  id        String     @id @default(uuid())
  email     String     @unique
  nombre    String?
  puntos    Int        @default(0)
  rol       Rol        @default(usuario)
  racha     Int        @default(0)
  ultimaConexion DateTime @default(now())
  progreso  Progreso[]
  insignias Insignia[]
  recursos  Recurso[]
  createdAt DateTime   @default(now())
}

model Seccion {
  id          Int         @id @default(autoincrement())
  nombre      String
  descripcion String
  nivel       Int
  grado       Int         @default(1)
  puntosRequeridos Int    @default(0)
  escenarios  Escenario[]
  recursoOtorgado Recurso?
}

model Escenario {
  id          Int         @id @default(autoincrement())
  titulo      String
  descripcion String
  pregunta    String
  explicacion String?
  categoria   String
  seccionId   Int
  seccion     Seccion     @relation(fields: [seccionId], references: [id])
  opciones    Opcion[]
  insignias   Insignia[]
  progreso    Progreso[]
}

model Opcion {
  id        Int      @id @default(autoincrement())
  texto     String
  puntos    Int      @default(0)
  escenarioId Int
  escenario   Escenario @relation(fields: [escenarioId], references: [id])
}

model Recurso {
  id          String   @id @default(uuid())
  nombre      String
  valor       Int      @default(1)
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  seccionId   Int      @unique
  seccion     Seccion  @relation(fields: [seccionId], references: [id])
  createdAt   DateTime @default(now())
}

model Insignia {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String
  imagenUrl   String?
  puntosRequeridos Int   @default(0)
  escenarioId Int
  escenario   Escenario @relation(fields: [escenarioId], references: [id])
  usuarios    Usuario[]
  createdAt   DateTime @default(now())
}

model Progreso {
  id              Int      @id @default(autoincrement())
  usuarioId       String
  escenarioId     Int
  puntosObtenidos Int      @default(0)
  resuelto        Boolean  @default(false)
  intentosFallidos Int     @default(0)
  usuario         Usuario  @relation(fields: [usuarioId], references: [id])
  escenario       Escenario @relation(fields: [escenarioId], references: [id])
  updatedAt       DateTime @updatedAt
}
